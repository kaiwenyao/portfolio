---
import Layout from '../layouts/Layout.astro';

const persona = {
  name: "Kaiwen Yao",
  title: "Software Engineer / Full Stack Developer",
  intro: "Passionate about technology and building elegant solutions. I love learning new things and collaborating with others. I'm a quick learner always ready to take on new challenges.",
  skills: [
    { name: "JavaScript", icon: "javascript" },
    { name: "TypeScript", icon: "typescript" },
    { name: "React", icon: "react" },
            { name: "Python", icon: "python" },
    { name: "Java", icon: "java" },
    { name: "Spring Boot", icon: "springboot" },
    { name: "Spring Cloud", icon: "springcloud" },
    { name: "PostgreSQL", icon: "postgresql" },
    { name: "MySQL", icon: "mysql" },
    { name: "Docker", icon: "docker" },
    { name: "AWS", icon: "aws" },
    { name: "Git", icon: "git" },
    { name: "Vue", icon: "vue" },
    { name: "C++", icon: "cplusplus" },
  ],
  socials: [
    { name: "GitHub", url: "https://github.com/yourusername", icon: "github" },
    { name: "LinkedIn", url: "https://linkedin.com/in/yourusername", icon: "linkedin" },
    { name: "Email", url: "mailto:your@email.com", icon: "mail" },
  ],
  education: [
    {
      period: "2024 - Present",
      degree: "M.S. Computer Science",
      school: "Your University",
      description: "Research focus / Key courses"
    },
    {
      period: "2020 - 2024",
      degree: "B.S. Related Major",
      school: "Your University",
      description: "Relevant courses / Projects"
    }
  ],
  experience: [
    {
      period: "2024 - Present",
      role: "Job Title",
      company: "Company Name",
      description: "Job description"
    }
  ],
  projects: [
    {
      name: "Project Name",
      tech: "Tech Stack",
      description: "Project description",
      url: "https://github.com/yourusername/project",
      highlight: "Project highlight"
    }
  ]
};

const navItems = [
  { name: "ABOUT", href: "#about" },
  { name: "EXPERIENCE", href: "#experience" },
  { name: "SKILLS", href: "#skills" },
  { name: "EDUCATION", href: "#education" },
  { name: "PROJECTS", href: "#projects" },
  { name: "CONTACT", href: "#contact" },
];

const icons: Record<string, string> = {
  github: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  externalLink: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>`,
  menu: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>`,
  close: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>`,
  arrow: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
};
---

<Layout title={`${persona.name} - ${persona.title}`} description={persona.intro}>
  <!-- Background Orbs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div class="bg-orb bg-orb-pink w-[500px] h-[500px] -top-48 -left-48 opacity-20"></div>
    <div class="bg-orb bg-orb-violet w-[600px] h-[600px] top-1/3 -right-64 opacity-15"></div>
    <div class="bg-orb bg-orb-cyan w-[400px] h-[400px] bottom-0 left-1/4 opacity-10"></div>
  </div>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0d1224]/80 backdrop-blur-xl border-b border-[#2a2e5a]/50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-white hover:text-[#f626af] transition-colors">
        {persona.name}
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class="text-sm text-[#99a1af] hover:text-[#f626af] transition-colors duration-300 tracking-wider"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden p-2 text-white hover:text-[#f626af] transition-colors" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu" set:html={icons.menu} />
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
      <ul class="flex flex-col gap-4">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class="text-sm text-[#99a1af] hover:text-[#f626af] transition-colors block tracking-wider"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main class="relative z-10 pt-20">
    <!-- Hero Section -->
    <section id="about" class="min-h-[90vh] flex items-center px-6 py-20 relative">
      <div class="max-w-7xl mx-auto w-full">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left: Personal Info -->
          <div class="stagger-children order-2 lg:order-1">
            <p class="text-[#f626af] text-sm tracking-[0.3em] mb-6 uppercase">Welcome to my portfolio</p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1]">
              Hello, I'm<br />
              <span class="gradient-text">{persona.name}</span>
            </h1>
            <p class="text-xl md:text-2xl text-[#d3d8e8] mb-8 leading-relaxed">
              {persona.title}
            </p>
            <p class="text-[#99a1af] mb-12 leading-relaxed">
              {persona.intro}
            </p>
            <div class="flex items-center gap-6">
              {persona.socials.map(social => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-3 rounded-xl bg-[#11152c] border border-[#2a2e5a] text-[#99a1af] hover:text-[#f626af] hover:border-[#f626af] transition-all duration-300 hover:scale-110"
                  aria-label={social.name}
                  set:html={icons[social.icon]}
                />
              ))}
            </div>
          </div>

          <!-- Right: Code Window -->
          <div class="order-1 lg:order-2 flex lg:justify-start lg:ml-12">
            <div class="w-full min-w-[700px] max-w-3xl">
              <!-- macOS Window Frame -->
              <div class="bg-[#1e1e2e] rounded-xl overflow-hidden shadow-2xl shadow-[#f626af]/10 border border-[#313244]">
                <!-- Title Bar -->
                <div class="flex items-center gap-2 px-4 py-3 bg-[#181825] border-b border-[#313244]">
                  <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                  <span class="ml-4 text-xs text-[#6c7086]">coder.js</span>
                </div>
                <!-- Code Content -->
                <div class="p-6 font-mono text-base leading-relaxed overflow-x-auto">
                  <div class="space-y-1 leading-tight">
                    <div><span class="text-[#cba6f7]">const</span> <span class="text-[#89dceb]">coder</span> <span class="text-[#cdd6f4]">=</span> <span class="text-[#cdd6f4]">{</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">name</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#a6e3a1]">'Kaiwen Yao'</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">skills</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">['C++'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'NextJS'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Vue'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Python'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'TypeScript'</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-10"><span class="text-[#a6e3a1]">'MySQL'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'MongoDB'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Docker'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'AWS'</span><span class="text-[#cdd6f4]">],</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">hardWorker</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">quickLearner</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">problemSolver</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">hireable</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#cdd6f4]">()</span> <span class="text-[#cdd6f4]">=></span> <span class="text-[#cdd6f4]">{</span></div>
                    <div class="pl-8"><span class="text-[#f9e2af]">return</span></div>
                    <div class="pl-10"><span class="text-[#cdd6f4]">(</span></div>
                    <div class="pl-10"><span class="text-[#cdd6f4]">this</span><span class="text-[#89b4fa]">.hardWorker</span></div>
                    <div class="pl-10"><span class="text-[#f9e2af]">&&</span> <span class="text-[#cdd6f4]">this</span><span class="text-[#89b4fa]">.problemSolver</span></div>
                    <div class="pl-10"><span class="text-[#f9e2af]">&&</span> <span class="text-[#cdd6f4]">this</span><span class="text-[#89b4fa]">.skills</span><span class="text-[#f9e2af]">.length</span><span class="text-[#f9e2af]">>=</span><span class="text-[#fab387]">5</span></div>
                    <div class="pl-10"><span class="text-[#cdd6f4]">);</span></div>
                    <div class="pl-8"><span class="text-[#cdd6f4]">}</span></div>
                    <div><span class="text-[#cdd6f4]">};</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Skills Marquee Section -->
    <section id="skills" class="py-16 relative overflow-hidden">
      <div class="section-divider mb-16 max-w-4xl mx-auto"></div>

      <div class="max-w-6xl mx-auto px-6 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">SKILLS</h2>
        <p class="text-[#99a1af] text-center">Technologies I work with</p>
      </div>

      <!-- Marquee Container -->
      <div class="relative overflow-hidden">
        <div class="flex gap-4 animate-marquee flex-nowrap">
          {persona.skills.map((skill) => (
            <div class="skill-card flex flex-col items-center gap-3 px-5 py-5 bg-[#11152c] border border-[#2a2e5a] rounded-xl min-w-[120px] cursor-pointer shrink-0">
              <img
                src={`/skills/${skill.icon}.svg`}
                alt={skill.name}
                class="w-16 h-16 object-contain"
                onerror={`this.src='/skills/${skill.icon}.png'`}
              />
              <span class="text-sm text-[#d3d8e8] font-medium">{skill.name}</span>
            </div>
          ))}
          {/* Second copy - only for seamless loop, hidden when reduced-motion */}
          <div class="reduced-motion-hidden flex gap-4 shrink-0">
            {persona.skills.map((skill) => (
              <div class="skill-card flex flex-col items-center gap-3 px-5 py-5 bg-[#11152c] border border-[#2a2e5a] rounded-xl min-w-[120px] cursor-pointer">
                <img
                  src={`/skills/${skill.icon}.svg`}
                  alt={skill.name}
                  class="w-16 h-16 object-contain"
                  onerror={`this.src='/skills/${skill.icon}.png'`}
                />
                <span class="text-sm text-[#d3d8e8] font-medium">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="section-divider mt-16 max-w-4xl mx-auto"></div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">EXPERIENCE</h2>
        <p class="text-[#99a1af] text-center mb-12">My professional journey</p>

        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#f626af] via-[#8228ec] to-transparent"></div>

          <div class="space-y-12">
            {persona.experience.map((exp, i) => (
              <div class="relative flex flex-col md:flex-row gap-8">
                <!-- Timeline dot -->
                <div class="absolute left-0 md:left-1/2 w-4 h-4 rounded-full bg-[#f626af] transform -translate-x-[6px] md:-translate-x-[7px] mt-6 glow-card"></div>

                <!-- Content -->
                <div class={`flex-1 ml-8 md:ml-0 ${i % 2 !== 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
                  <div class="card p-6 glow-card">
                    <div class="relative">
                      <span class="text-[#f626af] text-sm font-medium">{exp.period}</span>
                      <h3 class="text-xl font-bold text-white mt-2">{exp.role}</h3>
                      <div class="text-[#16f2b3] mt-1">{exp.company}</div>
                      <p class="text-[#99a1af] mt-3 leading-relaxed">{exp.description}</p>
                    </div>
                  </div>
                </div>

                <!-- Spacer for opposite side -->
                <div class="hidden md:block flex-1"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Education Section -->
    <section id="education" class="py-20 px-6 bg-[#050816]/50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">EDUCATION</h2>
        <p class="text-[#99a1af] text-center mb-12">My academic background</p>

        <div class="space-y-6">
          {persona.education.map((edu, i) => (
            <div class="glow-card">
              <div class="card p-6 relative">
                <div class="flex flex-col md:flex-row md:items-center gap-4">
                  <div class="flex-1">
                    <span class="text-[#8228ec] text-sm font-medium">{edu.period}</span>
                    <h3 class="text-xl font-bold text-white mt-2">{edu.degree}</h3>
                    <div class="text-[#16f2b3] mt-1">{edu.school}</div>
                  </div>
                  <div class="text-[#99a1af] text-sm leading-relaxed md:text-right max-w-md">
                    {edu.description}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">PROJECTS</h2>
        <p class="text-[#99a1af] text-center mb-12">Things I've built</p>

        <div class="grid md:grid-cols-2 gap-6">
          {persona.projects.map((project, i) => (
            <div class="glow-card">
              <div class="card p-6 h-full relative flex flex-col">
                <div class="flex items-start justify-between mb-3">
                  <h3 class="text-xl font-bold text-white">{project.name}</h3>
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#f626af] hover:text-[#16f2b3] transition-colors flex items-center gap-1 text-sm"
                  >
                    <span set:html={icons.externalLink} />
                  </a>
                </div>
                <span class="inline-block px-3 py-1 bg-[#f626af]/10 text-[#f626af] text-xs rounded-full w-fit mb-3">
                  {project.tech}
                </span>
                <p class="text-[#99a1af] flex-1 leading-relaxed">{project.description}</p>
                <p class="text-[#16f2b3] text-sm mt-4 flex items-center gap-2">
                  <span set:html={icons.arrow} />
                  {project.highlight}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 px-6 bg-[#050816]/50 relative">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="bg-orb bg-orb-pink w-[300px] h-[300px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-10"></div>
      </div>

      <div class="max-w-2xl mx-auto text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">GET IN TOUCH</h2>
        <p class="text-[#99a1af] mb-12 leading-relaxed">
          I'm always open to discussing new projects, creative ideas,<br class="hidden md:block" />
          or opportunities to be part of your visions.
        </p>

        <a
          href="mailto:your@email.com"
          class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-[#f626af] to-[#8228ec] text-white font-semibold rounded-xl hover:shadow-lg hover:shadow-[#f626af]/30 transition-all duration-300 hover:scale-105"
        >
          <span set:html={icons.mail} />
          Say Hello
        </a>

        <div class="flex items-center justify-center gap-6 mt-12">
          {persona.socials.map(social => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#99a1af] hover:text-[#f626af] transition-colors duration-300 hover:scale-110"
              aria-label={social.name}
              set:html={icons[social.icon]}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-[#2a2e5a]/50">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-[#99a1af] text-sm">
          © {new Date().getFullYear()} Kaiwen Yao. All rights reserved.
        </p>
        <p class="text-[#99a1af] text-sm">
          Built with <span class="text-[#f626af]">Astro</span> + <span class="text-[#8228ec]">Tailwind CSS</span>
        </p>
      </div>
    </footer>
  </main>
</Layout>

<style is:global>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee {
    animation: marquee 20s linear infinite;
  }

  .animate-marquee:hover {
    animation-play-state: paused;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
      overflow-x: auto;
    }
    .reduced-motion-hidden {
      display: none;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.toggle('hidden');
    menuBtn?.setAttribute('aria-expanded', String(!isHidden));
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Intersection Observer for fade-in animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-fade-in-up');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('section > div').forEach(el => {
    observer.observe(el);
  });
</script>
