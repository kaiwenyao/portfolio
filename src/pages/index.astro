---
import Layout from '../layouts/Layout.astro';

const persona = {
  name: "Kaiwen Yao",
  title: "Full-Stack Developer Focused on Spring + React Systems",
  intro:
    "I build practical products across the stack, from Spring Cloud services and transactional backends to React dashboards, mobile-first utilities, and polished Astro frontends. Recent public work includes a takeout admin console, a course-platform microservice suite, and a browser-based strategy toolkit.",
  focusAreas: [
    "Java 21 + Spring Cloud",
    "React 19 dashboards",
    "Docker / Jenkins delivery",
  ],
  stats: [
    { value: "3", label: "featured public builds" },
    { value: "9", label: "services in Demy" },
    { value: "2026", label: "recent shipping cadence" },
  ],
  skills: [
    { name: "TypeScript", icon: "typescript" },
    { name: "React", icon: "react" },
    { name: "Java", icon: "java" },
    { name: "Spring Boot", icon: "springboot" },
    { name: "Spring Cloud", icon: "springcloud" },
    { name: "Python", icon: "python" },
    { name: "MySQL", icon: "mysql" },
    { name: "PostgreSQL", icon: "postgresql" },
    { name: "Docker", icon: "docker" },
    { name: "AWS", icon: "aws" },
    { name: "Git", icon: "git" },
    { name: "Vue", icon: "vue" },
    { name: "Tailwind CSS", icon: "tailwind" },
    { name: "C++", icon: "cplusplus" },
  ],
  socials: [
    { name: "GitHub", url: "https://github.com/kaiwenyao", icon: "github" },
    { name: "Docker Hub", url: "https://hub.docker.com/u/kaiwenyao", icon: "docker" },
    { name: "Portfolio Repo", url: "https://github.com/kaiwenyao/portfolio", icon: "folder" },
  ],
  learning: [
    {
      period: "2026",
      degree: "Microservices Architecture Track",
      school: "Spring Boot 3.5, Spring Cloud 2025, Redis, RabbitMQ",
      description:
        "Applied through Demy, a Java 21 backend split into gateway, config, discovery, auth, course, order, enrollment, and user services.",
    },
    {
      period: "2025 - 2026",
      degree: "React Dashboard Engineering",
      school: "React 19, TypeScript, Tailwind CSS, shadcn/ui, ECharts",
      description:
        "Built a production-style admin console with analytics, live order notifications, CRUD workflows, and Docker + Jenkins deployment.",
    },
    {
      period: "2024 - 2026",
      degree: "Browser-First Tools and Experiments",
      school: "Vite, Material UI, Astro, automation tooling",
      description:
        "Shipped mobile-first utilities, automation experiments, and design-forward frontend work with a strong emphasis on clear UX.",
    },
  ],
  experience: [
    {
      period: "2026 - Present",
      role: "Independent Full-Stack Builder",
      company: "GitHub / Public Projects",
      description:
        "Shipping practical systems that combine backend architecture, frontend polish, and delivery automation instead of isolated toy demos.",
      outcomes: [
        "Built Demy as a Spring Cloud microservice platform with config, discovery, auth, enrollment, course, and order domains.",
        "Integrated Redis, RabbitMQ, Flyway, OpenFeign, validation, and transactional service logic in recent backend work.",
      ],
    },
    {
      period: "Late 2025 - Present",
      role: "Dashboard and Operations UI Developer",
      company: "Firmament Takeaway Admin",
      description:
        "Designed a modern admin console for a takeaway platform with strong day-to-day operational workflows.",
      outcomes: [
        "Implemented dashboards, employee management, order flows, dishes, set meals, categories, and real-time notifications.",
        "Containerized the frontend and wired Jenkins-driven delivery for repeatable deployment.",
      ],
    },
    {
      period: "2024 - Present",
      role: "Tooling and Interaction Experimenter",
      company: "Utilities, automation, and browser products",
      description:
        "Using side projects to pressure-test new frameworks, UI patterns, and developer workflows across different formats.",
      outcomes: [
        "Built SGS Tools as a mobile-first browser toolkit for fast tactical decision support.",
        "Continued exploring Astro, React, Docker, and Java service design through public repos and iterative releases.",
      ],
    },
  ],
  projects: [
    {
      name: "Firmament Takeaway Admin",
      tech: "React 19 · TypeScript · Tailwind CSS · shadcn/ui · ECharts · Docker · Jenkins",
      description:
        "A polished admin console for takeaway operations with dashboards, order management, menu workflows, employee tools, and live order updates.",
      url: "https://github.com/kaiwenyao/firmament-take-out-admin",
      demoUrl: "https://firmament-admin.kaiwen.dev",
      highlight: "Production-style frontend delivery with Docker, nginx, and Jenkins automation.",
    },
    {
      name: "Demy",
      tech: "Java 21 · Spring Boot · Spring Cloud · MySQL · Redis · RabbitMQ · Flyway",
      description:
        "A microservice-based learning platform backend organized around gateway, config, discovery, auth, course, enrollment, user, and order services.",
      url: "https://github.com/kaiwenyao/demy",
      demoUrl: "",
      highlight: "Nine-service architecture with real transaction handling and service-to-service integration.",
    },
    {
      name: "SGS Tools",
      tech: "React · TypeScript · Vite · Material UI · Tailwind CSS · Docker",
      description:
        "A mobile-first browser toolkit that turns repetitive game-state calculations and probability judgments into fast, touch-friendly flows.",
      url: "https://github.com/kaiwenyao/sgs-tools",
      demoUrl: "",
      highlight: "Compact utility product with clear mobile UX and Dockerized deployment.",
    },
  ],
};

const navItems = [
  { name: "ABOUT", href: "#about" },
  { name: "EXPERIENCE", href: "#experience" },
  { name: "SKILLS", href: "#skills" },
  { name: "LEARNING", href: "#learning" },
  { name: "PROJECTS", href: "#projects" },
  { name: "CONTACT", href: "#contact" },
];

const icons: Record<string, string> = {
  github: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  docker: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13.983 11.758h1.985v-1.97h-1.985zm-2.976 0h1.984v-1.97h-1.984zm-2.976 0h1.984v-1.97H8.031zm8.928 0h1.985v-1.97h-1.985zm-2.976-2.625h1.985V7.164h-1.985zm-2.976 0h1.984V7.164h-1.984zm4.961 4.641c-.828 0-1.554-.457-1.936-1.133-.382.676-1.108 1.133-1.936 1.133H1.5c.176 1.937 1.164 3.666 2.758 4.944 1.59 1.276 3.635 1.992 5.742 1.992 4.918 0 8.994-3.786 9.444-8.586.465-.086 1.064-.3 1.58-.738.788-.66 1.252-1.695 1.465-3.064.043-.278-.106-.557-.366-.678-.711-.332-1.715-.433-2.713-.137-.382.114-.734.29-1.026.514-.566-1.563-1.961-2.635-3.456-2.635-.264 0-.478.211-.478.472v1.75h1.494v1.969z"/></svg>`,
  folder: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.94l-.81-1.22A2 2 0 0 0 7.92 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>`,
  externalLink: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>`,
  menu: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>`,
  arrow: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
};
---

<Layout title={`${persona.name} - ${persona.title}`} description={persona.intro}>
  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div class="bg-orb bg-orb-pink w-[500px] h-[500px] -top-48 -left-48 opacity-20"></div>
    <div class="bg-orb bg-orb-violet w-[600px] h-[600px] top-1/3 -right-64 opacity-15"></div>
    <div class="bg-orb bg-orb-cyan w-[420px] h-[420px] bottom-0 left-1/4 opacity-10"></div>
  </div>

  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0d1224]/80 backdrop-blur-xl border-b border-[#2a2e5a]/50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-white hover:text-[#f626af] transition-colors">
        {persona.name}
      </a>

      <ul class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-[#99a1af] hover:text-[#f626af] transition-colors duration-300 tracking-wider"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="menu-btn"
        class="md:hidden p-2 text-white hover:text-[#f626af] transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        set:html={icons.menu}
      />
    </div>

    <div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
      <ul class="flex flex-col gap-4">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-[#99a1af] hover:text-[#f626af] transition-colors block tracking-wider"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main class="relative z-10 pt-20">
    <section id="about" class="min-h-[90vh] flex items-center px-6 py-20 relative">
      <div class="max-w-7xl mx-auto w-full">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="stagger-children order-2 lg:order-1">
            <p class="text-[#f626af] text-sm tracking-[0.3em] mb-6 uppercase">Open-source, product-minded, shipping</p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1]">
              Kaiwen builds<br />
              <span class="gradient-text">useful software.</span>
            </h1>
            <p class="text-xl md:text-2xl text-[#d3d8e8] mb-6 leading-relaxed">
              {persona.title}
            </p>
            <p class="text-[#99a1af] mb-8 leading-relaxed max-w-2xl">
              {persona.intro}
            </p>

            <div class="flex flex-wrap gap-3 mb-10">
              {persona.focusAreas.map((area) => (
                <span class="px-4 py-2 rounded-full bg-[#11152c]/90 border border-[#2a2e5a] text-sm text-[#d3d8e8]">
                  {area}
                </span>
              ))}
            </div>

            <div class="flex flex-wrap items-center gap-4 mb-10">
              <a
                href="#projects"
                class="inline-flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-[#f626af] to-[#8228ec] text-white font-semibold rounded-xl hover:shadow-lg hover:shadow-[#f626af]/30 transition-all duration-300 hover:scale-[1.03]"
              >
                Explore Projects
                <span set:html={icons.arrow} />
              </a>
              <a
                href="https://github.com/kaiwenyao"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 px-6 py-3 rounded-xl border border-[#2a2e5a] bg-[#11152c]/80 text-[#d3d8e8] hover:text-white hover:border-[#16f2b3] transition-colors"
              >
                <span set:html={icons.github} />
                View GitHub
              </a>
            </div>

            <div class="grid sm:grid-cols-3 gap-4">
              {persona.stats.map((stat) => (
                <div class="card p-4">
                  <div class="text-2xl font-bold text-white">{stat.value}</div>
                  <div class="text-sm text-[#99a1af] mt-1">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>

          <div class="order-1 lg:order-2 flex lg:justify-start lg:ml-12">
            <div class="w-full max-w-3xl">
              <div class="bg-[#1e1e2e] rounded-xl overflow-hidden shadow-2xl shadow-[#f626af]/10 border border-[#313244]">
                <div class="flex items-center gap-2 px-4 py-3 bg-[#181825] border-b border-[#313244]">
                  <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                  <span class="ml-4 text-xs text-[#6c7086]">profile.ts</span>
                </div>
                <div class="p-6 font-mono text-sm md:text-base leading-relaxed overflow-x-auto">
                  <div class="space-y-1 leading-tight min-w-[18rem]">
                    <div><span class="text-[#cba6f7]">const</span> <span class="text-[#89dceb]">builder</span> <span class="text-[#cdd6f4]">=</span> <span class="text-[#cdd6f4]">{`{`}</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">name</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#a6e3a1]">'Kaiwen Yao'</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">handle</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#a6e3a1]">'kaiwenyao'</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">focus</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#cdd6f4]">[</span><span class="text-[#a6e3a1]">'Spring Cloud'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'React 19'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Astro'</span><span class="text-[#cdd6f4]">],</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">shipping</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#cdd6f4]">[</span><span class="text-[#a6e3a1]">'Demy'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Firmament Admin'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'SGS Tools'</span><span class="text-[#cdd6f4]">],</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">deploysWith</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#cdd6f4]">[</span><span class="text-[#a6e3a1]">'Docker'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'Jenkins'</span><span class="text-[#cdd6f4]">,</span> <span class="text-[#a6e3a1]">'nginx'</span><span class="text-[#cdd6f4]">],</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">values</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#cdd6f4]">{`{`}</span></div>
                    <div class="pl-10"><span class="text-[#89b4fa]">practicality</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-10"><span class="text-[#89b4fa]">systemsThinking</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-10"><span class="text-[#89b4fa]">uiPolish</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#f9e2af]">true</span></div>
                    <div class="pl-6"><span class="text-[#cdd6f4]">{`}`}</span><span class="text-[#cdd6f4]">,</span></div>
                    <div class="pl-6"><span class="text-[#89b4fa]">nextStep</span><span class="text-[#cdd6f4]">:</span> <span class="text-[#a6e3a1]">'Build products that feel production-ready, not unfinished'</span></div>
                    <div><span class="text-[#cdd6f4]">{`}`};</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="py-16 relative overflow-hidden">
      <div class="section-divider mb-16 max-w-4xl mx-auto"></div>

      <div class="max-w-6xl mx-auto px-6 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">SKILLS</h2>
        <p class="text-[#99a1af] text-center">Technologies repeatedly used across Kaiwen Yao's public portfolio work</p>
      </div>

      <div class="relative overflow-hidden">
        <div class="flex gap-4 animate-marquee flex-nowrap">
          {persona.skills.map((skill) => (
            <div class="skill-card flex flex-col items-center gap-3 px-5 py-5 bg-[#11152c] border border-[#2a2e5a] rounded-xl min-w-[120px] cursor-pointer shrink-0">
              <img
                src={`/skills/${skill.icon}.svg`}
                alt={skill.name}
                class="w-16 h-16 object-contain"
                onerror={`this.src='/skills/${skill.icon}.png'`}
              />
              <span class="text-sm text-[#d3d8e8] font-medium">{skill.name}</span>
            </div>
          ))}
          <div class="reduced-motion-hidden flex gap-4 shrink-0">
            {persona.skills.map((skill) => (
              <div class="skill-card flex flex-col items-center gap-3 px-5 py-5 bg-[#11152c] border border-[#2a2e5a] rounded-xl min-w-[120px] cursor-pointer">
                <img
                  src={`/skills/${skill.icon}.svg`}
                  alt={skill.name}
                  class="w-16 h-16 object-contain"
                  onerror={`this.src='/skills/${skill.icon}.png'`}
                />
                <span class="text-sm text-[#d3d8e8] font-medium">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="section-divider mt-16 max-w-4xl mx-auto"></div>
    </section>

    <section id="experience" class="py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">EXPERIENCE</h2>
        <p class="text-[#99a1af] text-center mb-12">Recent work themes reflected in Kaiwen's public builds</p>

        <div class="relative">
          <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#f626af] via-[#8228ec] to-transparent"></div>

          <div class="space-y-12">
            {persona.experience.map((exp, i) => (
              <div class="relative flex flex-col md:flex-row gap-8">
                <div class="absolute left-0 md:left-1/2 w-4 h-4 rounded-full bg-[#f626af] transform -translate-x-[6px] md:-translate-x-[7px] mt-6 glow-card"></div>

                <div class={`flex-1 ml-8 md:ml-0 ${i % 2 !== 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
                  <div class="card p-6 glow-card">
                    <div class="relative">
                      <span class="text-[#f626af] text-sm font-medium">{exp.period}</span>
                      <h3 class="text-xl font-bold text-white mt-2">{exp.role}</h3>
                      <div class="text-[#16f2b3] mt-1">{exp.company}</div>
                      <p class="text-[#99a1af] mt-3 leading-relaxed">{exp.description}</p>
                      <div class="mt-5 space-y-3">
                        {exp.outcomes.map((outcome) => (
                          <p class="text-sm text-[#d3d8e8] leading-relaxed flex items-start gap-3 justify-start md:justify-end">
                            <span class="text-[#16f2b3] mt-1">•</span>
                            <span>{outcome}</span>
                          </p>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <div class="hidden md:block flex-1"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="learning" class="py-20 px-6 bg-[#050816]/50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">LEARNING PATH</h2>
        <p class="text-[#99a1af] text-center mb-12">Concrete areas of study supported by recent public repositories</p>

        <div class="space-y-6">
          {persona.learning.map((item) => (
            <div class="glow-card">
              <div class="card p-6 relative">
                <div class="flex flex-col md:flex-row md:items-center gap-4">
                  <div class="flex-1">
                    <span class="text-[#8228ec] text-sm font-medium">{item.period}</span>
                    <h3 class="text-xl font-bold text-white mt-2">{item.degree}</h3>
                    <div class="text-[#16f2b3] mt-1">{item.school}</div>
                  </div>
                  <div class="text-[#99a1af] text-sm leading-relaxed md:text-right max-w-md">
                    {item.description}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">PROJECTS</h2>
